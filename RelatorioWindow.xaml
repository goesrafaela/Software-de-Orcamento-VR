<Window x:Class="OrcaPro.RelatorioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relatório Financeiro"
        Height="600"
        Width="900"
        Background="#F3F6FA"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <!-- FILTRO -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                <StackPanel Margin="5">
                    <TextBlock Text="Ano"/>
                    <ComboBox x:Name="AnoFiltro"
                              Width="100"
                              SelectionChanged="CarregarDados"/>
                </StackPanel>

            </StackPanel>

            <!-- TOTAL -->
            <TextBlock x:Name="TotalAnoText"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,10"/>

            <!-- GRID -->
            <DataGrid x:Name="RelatorioGrid"
                      Height="200"
                      AutoGenerateColumns="True"/>

            <!-- GRÁFICO (SIMPLES COM LISTVIEW) -->
            <TextBlock Text="Faturamento por mês"
                       FontSize="18"
                       Margin="0,20,0,10"/>

            <ItemsControl x:Name="GraficoPanel"/>

        </StackPanel>

    </Grid>
</Window>
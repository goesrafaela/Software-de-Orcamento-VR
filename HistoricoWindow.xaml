<Window x:Class="OrcaPro.HistoricoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico"
        Height="650"
        Width="1200"
        Background="#F3F6FA"
        WindowStartupLocation="CenterScreen"
         WindowState="Maximized"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">

        <StackPanel>

            <!-- TÍTULO -->
            <TextBlock Text="Histórico de Orçamentos"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- GRID -->
            <DataGrid x:Name="HistoricoGrid"
                      AutoGenerateColumns="False"
                      Height="520"
                      LoadingRow="Grid_LoadingRow">

                <DataGrid.Columns>

                    <!-- ID -->
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="60"/>

                    <!-- CLIENTE -->
                    <DataGridTextColumn Header="Cliente"
                                        Binding="{Binding Cliente}"
                                        Width="180"/>

                    <!-- SERVIÇOS -->
                    <DataGridTextColumn Header="Serviços"
                                        Binding="{Binding Servicos}"
                                        Width="250"/>

                    <!-- TOTAL -->
                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding Total}"
                                        Width="120"/>

                    <!-- STATUS -->
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="120"/>

                    <!-- PARCELAS -->
                    <DataGridTextColumn Header="Parcelas"
                                        Binding="{Binding Parcelas}"
                                        Width="90"/>

                    <!-- PAGAMENTOS -->
                    <DataGridTemplateColumn Header="Pagamentos"
                                            Width="350">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <ItemsControl ItemsSource="{Binding Pagamentos}">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>

                                        <DataTemplate>

                                            <CheckBox Content="{Binding Nome}"
                                                      IsChecked="{Binding Pago}"
                                                      Margin="5"/>

                                        </DataTemplate>

                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

    </Grid>
</Window>
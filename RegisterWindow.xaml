<Window x:Class="OrcaPro.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Criar conta"
        Height="520"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F6FA">

    <Grid>
        <Border Background="White"
                CornerRadius="12"
                Padding="25"
                Width="300"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Criar conta"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Preencha os dados abaixo"
                           Foreground="#777"
                           FontSize="12"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <!-- Nome -->
                <TextBlock Text="Nome completo"
                           FontSize="12"
                           Foreground="#555"/>
                <TextBox x:Name="NomeBox"
                         Height="32"
                         Margin="0,5,0,10"
                         Padding="5"/>

                <!-- Email -->
                <TextBlock Text="E-mail"
                           FontSize="12"
                           Foreground="#555"/>
                <TextBox x:Name="EmailBox"
                         Height="32"
                         Margin="0,5,0,10"
                         Padding="5"/>

                <!-- Senha -->
                <TextBlock Text="Senha"
                           FontSize="12"
                           Foreground="#555"/>
                <PasswordBox x:Name="SenhaBox"
                             Height="32"
                             Margin="0,5,0,15"
                             Padding="5"/>

                <!-- Mensagem de erro -->
                <TextBlock x:Name="ErroText"
                           Foreground="Red"
                           FontSize="11"
                           Visibility="Collapsed"
                           Margin="0,0,0,10"/>

                <!-- Botão -->
                <Button Content="Criar conta"
                        Height="36"
                        Background="#1E5FA8"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Cadastrar_Click"/>

                <!-- Voltar -->
                <TextBlock Text="Já tem conta? Entrar"
                           Margin="0,15,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#1E5FA8"
                           Cursor="Hand"
                           MouseDown="VoltarLogin_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
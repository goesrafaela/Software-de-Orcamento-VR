<Window x:Class="OrcaPro.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clientes"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">

        <StackPanel>

            <!-- Formulário -->
            <StackPanel Orientation="Horizontal" Margin="0,10">

                <!-- Nome -->
                <StackPanel Margin="5">
                    <TextBlock Text="Nome"
                               FontSize="12"
                               Foreground="#555"/>
                    <TextBox x:Name="NomeBox"
                             Width="150"
                             Height="30"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Margin="5">
                    <TextBlock Text="E-mail"
                               FontSize="12"
                               Foreground="#555"/>
                    <TextBox x:Name="EmailBox"
                             Width="150"
                             Height="30"/>
                </StackPanel>

                <!-- Telefone -->
                <StackPanel Margin="5">
                    <TextBlock Text="Telefone"
                               FontSize="12"
                               Foreground="#555"/>
                    <TextBox x:Name="TelefoneBox"
                             Width="120"
                             Height="30"/>
                </StackPanel>

                <!-- Botões -->
                <StackPanel Margin="5" VerticalAlignment="Bottom">
                    <Button Content="Adicionar"
                            Height="30"
                            Margin="0,0,0,5"
                            Click="Adicionar_Click"/>

                    <Button Content="Editar"
                            Height="30"
                            Background="#F0AD4E"
                            Foreground="White"
                            Click="Editar_Click"/>
                </StackPanel>

            </StackPanel>

            <!-- Lista -->
            <DataGrid x:Name="ClientesGrid"
                      Margin="0,10"
                      AutoGenerateColumns="True"
                      Height="300"
                      SelectionChanged="ClientesGrid_SelectionChanged"/>

            <!-- Excluir -->
            <Button Content="Excluir selecionado"
                    Width="150"
                    Height="30"
                    Margin="0,10,0,0"
                    Background="#D9534F"
                    Foreground="White"
                    Click="Excluir_Click"/>

        </StackPanel>

    </Grid>
</Window>
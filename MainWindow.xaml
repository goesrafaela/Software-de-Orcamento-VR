<Window x:Class="OrcaPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="500"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E9EEF3">

    <Grid>
        <Border Background="White"
                Padding="20"
                CornerRadius="10"
                Width="280"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="OrçaPro"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Sistema de gestão de orçamentos"
                           FontSize="12"
                           Foreground="Gray"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="EmailBox"
                         Height="30"
                         Margin="0,5"/>

                <PasswordBox x:Name="SenhaBox"
                             Height="30"
                             Margin="0,5"/>

                <Button Content="Entrar"
                        Height="35"
                        Margin="0,10"
                        Background="#1E5FA8"
                        Foreground="White"
                        Click="Login_Click"/>

                <TextBlock Text="Criar conta"
                           Foreground="Blue"
                           Cursor="Hand"
                           HorizontalAlignment="Center"
                           MouseDown="AbrirCadastro"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
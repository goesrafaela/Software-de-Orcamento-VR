<Window x:Class="OrcaPro.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">

    <Grid>

        <!-- Sidebar -->
        <Border Background="#1E293B" Width="200" HorizontalAlignment="Left">
            <StackPanel Margin="10">

                <TextBlock Text="VR Reservatórios"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Dashboard"
                        Margin="10"
                        Height="35"/>

                <Button Content="Clientes"
                        Margin="10"
                        Height="35"
                        Click="AbrirClientes_Click"/>

                <Button Content="Orçamentos"
                        Margin="10"
                        Height="35"/>

                <Button Content="Sair"
                        Margin="10"
                        Height="35"
                        Click="Sair_Click"/>

            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Margin="210,20,20,20">

            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Bem-vindo ao sistema!"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- Cards -->
                <WrapPanel>

                    <Border Background="White"
                            Width="200"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">
                            <TextBlock Text="Clientes"
                                       FontWeight="Bold"/>
                            <TextBlock Text="0"
                                       FontSize="20"/>
                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            Width="200"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">
                            <TextBlock Text="Orçamentos"
                                       FontWeight="Bold"/>
                            <TextBlock Text="0"
                                       FontSize="20"/>
                        </StackPanel>

                    </Border>

                </WrapPanel>

            </StackPanel>

        </Grid>

    </Grid>
</Window>
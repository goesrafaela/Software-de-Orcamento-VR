<Window x:Class="OrcaPro.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow">

    <Grid>

        <!-- Sidebar -->
        <Border Background="#1E293B" Width="200" HorizontalAlignment="Left">
            <StackPanel Margin="10">

                <TextBlock Text="VR Reservatórios"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Dashboard" Margin="10" Height="35"/>
                <Button Content="Clientes" Margin="10" Height="35" Click="AbrirClientes_Click"/>
                <Button Content="Orçamentos" Margin="10" Height="35" Click="AbrirOrcamentos_Click"/>
                <Button Content="Sair" Margin="10" Height="35" Click="Sair_Click"/>

            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Margin="210,20,20,20">

            <StackPanel>

                <TextBlock Text="Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- CARDS -->
                <WrapPanel>

                    <!-- CLIENTES -->
                    <Border Background="White" Width="180" Height="100" Margin="10" CornerRadius="10">
                        <StackPanel Margin="10">
                            <TextBlock Text="Clientes"/>
                            <TextBlock x:Name="ClientesCount" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- EM ANDAMENTO -->
                    <Border Background="#FFF3CD" Width="180" Height="100" Margin="10" CornerRadius="10">
                        <StackPanel Margin="10">
                            <TextBlock Text="Em andamento"/>
                            <TextBlock x:Name="EmAndamentoCount" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- APROVADOS -->
                    <Border Background="#D4EDDA" Width="180" Height="100" Margin="10" CornerRadius="10">
                        <StackPanel Margin="10">
                            <TextBlock Text="Aprovados"/>
                            <TextBlock x:Name="AprovadosCount" FontSize="22" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- FATURAMENTO -->
                    <Border Background="#D1ECF1" Width="220" Height="100" Margin="10" CornerRadius="10">
                        <StackPanel Margin="10">
                            <TextBlock Text="Faturamento"/>
                            <TextBlock x:Name="FaturamentoText" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>

                <!-- LISTA DE ORÇAMENTOS -->
                <TextBlock Text="Orçamentos recentes"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>

                <DataGrid x:Name="OrcamentosGrid"
                          Height="300"
                          AutoGenerateColumns="True"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>
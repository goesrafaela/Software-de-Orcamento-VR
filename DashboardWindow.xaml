<Window x:Class="OrcaPro.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow">

    <Grid>

        <!-- SIDEBAR -->
        <Border Background="#1E293B"
                Width="200"
                HorizontalAlignment="Left">

            <StackPanel Margin="10">

                <TextBlock Text="VR Reservatórios"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Dashboard"
                        Margin="10"
                        Height="35"/>

                <Button Content="Clientes"
                        Margin="10"
                        Height="35"
                        Click="AbrirClientes_Click"/>

                <Button Content="Orçamentos"
                        Margin="10"
                        Height="35"
                        Click="AbrirOrcamentos_Click"/>

                <Button Content="Histórico"
                        Margin="10"
                        Height="35"
                        Click="AbrirHistorico_Click"/>

                <Button Content="Relatórios"
                        Margin="10"
                        Height="35"
                        Click="AbrirRelatorio_Click"/>

                <Button Content="Sair"
                        Margin="10"
                        Height="35"
                        Click="Sair_Click"/>

            </StackPanel>

        </Border>

        <!-- CONTEÚDO -->
        <Grid Margin="210,20,20,20">

            <StackPanel>

                <!-- TÍTULO -->
                <TextBlock Text="Dashboard"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <!-- CARDS -->
                <WrapPanel>

                    <!-- CLIENTES -->
                    <Border Background="White"
                            Width="180"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Clientes"
                                       FontSize="14"/>

                            <TextBlock x:Name="ClientesCount"
                                       FontSize="24"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <!-- EM ANDAMENTO -->
                    <Border Background="#FFF3CD"
                            Width="180"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Em andamento"
                                       FontSize="14"/>

                            <TextBlock x:Name="EmAndamentoCount"
                                       FontSize="24"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <!-- APROVADOS -->
                    <Border Background="#D4EDDA"
                            Width="180"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Aprovados"
                                       FontSize="14"/>

                            <TextBlock x:Name="AprovadosCount"
                                       FontSize="24"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <!-- FATURAMENTO TOTAL -->
                    <Border Background="#D1ECF1"
                            Width="220"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Faturamento Total"
                                       FontSize="14"/>

                            <TextBlock x:Name="FaturamentoText"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <!-- FATURAMENTO MÊS -->
                    <Border Background="#FFE8A1"
                            Width="220"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Faturamento do Mês"
                                       FontSize="14"/>

                            <TextBlock x:Name="FaturamentoMesText"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <!-- LUCRO BRUTO -->
                    <Border Background="#C8F7C5"
                            Width="220"
                            Height="100"
                            Margin="10"
                            CornerRadius="10">

                        <StackPanel Margin="10">

                            <TextBlock Text="Lucro Bruto"
                                       FontSize="14"/>

                            <TextBlock x:Name="LucroBrutoText"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                </WrapPanel>

                <!-- TÍTULO GRID -->
                <TextBlock Text="Orçamentos recentes"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>

                <!-- GRID -->
                <DataGrid x:Name="OrcamentosGrid"
                          Height="320"
                          Margin="0,0,0,10"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Cliente"
                                            Binding="{Binding Cliente}"
                                            Width="250"/>

                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding Total}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="180"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- BOTÕES -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Aprovar"
                            Width="120"
                            Height="35"
                            Margin="5"
                            Background="#28A745"
                            Foreground="White"
                            Click="Aprovar_Click"/>

                    <Button Content="Em andamento"
                            Width="140"
                            Height="35"
                            Margin="5"
                            Background="#FFC107"
                            Click="Andamento_Click"/>

                    <Button Content="Finalizar"
                            Width="120"
                            Height="35"
                            Margin="5"
                            Background="#17A2B8"
                            Foreground="White"
                            Click="Finalizar_Click"/>

                </StackPanel>

            </StackPanel>

        </Grid>

    </Grid>
</Window>
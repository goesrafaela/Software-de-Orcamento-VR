<Window x:Class="OrcaPro.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">

    <Grid>

        <!-- Sidebar -->
        <Border Background="#1E293B" Width="200" HorizontalAlignment="Left">
            <StackPanel Margin="10">

                <TextBlock Text="OrçaPro"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10"/>

                <Button Content="Dashboard"
                        Margin="10"
                        Height="35"/>

                <Button Content="Clientes"
                        Margin="10"
                        Height="35"/>

                <Button Content="Orçamentos"
                        Margin="10"
                        Height="35"/>

                <Button Content="Sair"
                        Margin="10"
                        Height="35"
                        Click="Sair_Click"/>

            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <Grid Margin="210,20,20,20">

            <TextBlock Text="Bem-vindo ao sistema!"
                       FontSize="24"
                       FontWeight="Bold"/>

        </Grid>

    </Grid>
</Window>